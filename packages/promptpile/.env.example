# AI API 配置
AI_API_KEY=sk-your-api-key-here
AI_MODEL=deepseek-chat
AI_API_BASE_URL=https://api.deepseek.com/v1

# 默认配置
DEFAULT_DIRECTORY=./messages

# 可选：仅从此文件加载 tools（.jsonl 或 .toml；相对路径相对于扫描目录根，见 README「工具定义」）
# TOOLS_FILE=

# 可选：本轮成功后执行的脚本（相对路径相对于扫描目录根，见 README「完成后钩子」）
# AFTER_HOOK_PATH=

# 可选：OpenAI tool_choice（none | auto | required | function:<name>），仅当请求含 tools 时写入 API；见 README「配置说明」
# TOOL_CHOICE=