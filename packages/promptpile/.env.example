# AI API 配置
AI_API_KEY=sk-your-api-key-here
AI_MODEL=deepseek-chat
AI_API_BASE_URL=https://api.deepseek.com/v1

# 默认配置（也可用 PROMPTPILE_DIR；与 cwd、TOML、CLI 的合并优先级见 README「配置说明」）
DEFAULT_DIRECTORY=./messages
# PROMPTPILE_DIR=./messages

# 扫描目录（DEFAULT_DIRECTORY 解析后）下也可放置 .env，优先级高于本文件

# 可选：从此 .toml 加载工具（可含 extends；相对路径相对于扫描目录根，见 README「工具定义」）。未设置时须使用 --tools-file 或 --disable-tool。
# TOOLS_FILE=my-tools.toml

# 可选：本轮成功后执行的脚本（相对路径相对于扫描目录根，见 README「完成后钩子」）
# AFTER_HOOK_PATH=

# 可选：OpenAI tool_choice（none | auto | required | function:<name>），仅当请求含 tools 时写入 API；见 README「配置说明」
# TOOL_CHOICE=

# 可选：诊断日志（stderr，前缀 [promptpile]）；与 QUIET 同时启用时仍会输出
# PROMPTPILE_DEBUG=1