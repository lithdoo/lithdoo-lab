{
  "name": "promptpile-react",
  "version": "1.0.0",
  "description": "在 promptpile CLI 之上的 agent 编排（子进程调用 CLI；`-i` 写入 user 消息时依赖 workspace `promptpile` 包内的 file-handler）",
  "main": "dist/index.js",
  "bin": {
    "promptpile-react": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts"
  },
  "keywords": [
    "promptpile-react",
    "promptpile",
    "react",
    "command-line"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "dependencies": {
    "@types/node": "^25.5.2",
    "commander": "^14.0.3",
    "promptpile": "file:../promptpile",
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "ts-node": "^10.9.2"
  }
}
