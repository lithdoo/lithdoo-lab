# 扁平环境变量示例（与 example.toml 意图一致）。
# 键名均为大写下划线。嵌套 TOML 路径拼成前缀_子段，例如：
#   promptpile-react.max_step  ->  PROMPTPILE_REACT_MAX_STEP
#   promptpile.llm_api_base_url  ->  PROMPTPILE_LLM_API_BASE_URL
#
# 合并优先级（与 resolveReactConfig 一致）：
#   CLI > [promptpile-react] TOML > PROMPTPILE_REACT_*（扫描目录 .env → cwd .env → process.env）
#   > [promptpile] TOML 同名共享键 > PROMPTPILE_* / TOOLS_FILE（扫描目录 .env → cwd .env → process.env）
# 子进程不传 --config；[promptpile] 的 format/output/tool_choice 等由 react 忽略
#
# 环境变量不支持 [[llm_api]] 数组：每个具名 profile 使用
#   LLM_API_<PROFILE 名大写>_MODEL | _BASE_URL | _API_KEY | _API_KEY_ENV
# _API_KEY_ENV：值为「另一个环境变量的名称」（不要带 $），运行时从用户/系统环境中按该名读取密钥；
# 与 _API_KEY 并存时，建议实现为 _API_KEY_ENV 优先（不把密钥写进本文件）。
#
# 路径语义：
#   PROMPTPILE_TOOLS_FILE / TOOLS_FILE — 相对扫描目录根（子进程 promptpile）。
#   promptpile-react CLI --tools-file — 相对当前工作目录（cwd）。
#   PROMPTPILE_AFTER_HOOK / AFTER_HOOK_PATH — 相对扫描目录根；CLI --after-hook-path — 相对 cwd。
#
# PROMPTPILE_REACT_* 由 resolveReactConfig 读取；未配置 prompt 路径时回退 .react.*.md

# --- LLM API 多档配置（对应 [[llm_api]] name="deepseek" / "openai"）---
LLM_API_DEEPSEEK_MODEL=chat
LLM_API_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
LLM_API_DEEPSEEK_API_KEY=
LLM_API_DEEPSEEK_API_KEY_ENV=DEEPSEEK_API_KEY

LLM_API_OPENAI_MODEL=chat
LLM_API_OPENAI_BASE_URL=https://api.deepseek.com/v1
LLM_API_OPENAI_API_KEY=
LLM_API_OPENAI_API_KEY_ENV=OPENAI_API_KEY

# --- [promptpile] 主表（子进程 promptpile；与 packages/promptpile/example.env 对齐）---
PROMPTPILE_DIR=./message
PROMPTPILE_FORMAT=text
# 模型回复写入的主输出文件路径；不设置则仅 stdout（TOML 里 output=true 对真实运行无效，应改为路径）。
# PROMPTPILE_OUTPUT=./message/promptpile-react-example-output.md
PROMPTPILE_QUIET=false
PROMPTPILE_AFTER_HOOK=./after_hook.sh
PROMPTPILE_TOOL_CHOICE=auto
PROMPTPILE_TOOLS_FILE=./.tools.toml
# TOOLS_FILE=./.tools.toml
PROMPTPILE_DISABLE_TOOL=false
PROMPTPILE_CONTINUE=false
PROMPTPILE_INPUT=true
# PROMPTPILE_INSERT_FILES=./inject.system.md

PROMPTPILE_LLM_API=deepseek
PROMPTPILE_LLM_API_KEY=
PROMPTPILE_LLM_API_KEY_ENV=
PROMPTPILE_LLM_API_MODEL=
PROMPTPILE_LLM_API_BASE_URL=
PROMPTPILE_LLM_API_TEMPERATURE=0.8
PROMPTPILE_LLM_API_EXTRA_BODY={"top_p":0.9}

# 子进程单次调用仍可读（转发 CLI 时常用）
# AI_API_KEY=
# AI_MODEL=
# AI_API_BASE_URL=

# --- [promptpile-react] 编排层（未配置项实现后回退到上方 PROMPTPILE_* 同名语义）---
PROMPTPILE_REACT_DIR=./message
PROMPTPILE_REACT_QUIET=false
PROMPTPILE_REACT_AFTER_HOOK=./after_hook.sh
PROMPTPILE_REACT_TOOLS_FILE=./.tools.toml
PROMPTPILE_REACT_CONTINUE=false
PROMPTPILE_REACT_INPUT=true

PROMPTPILE_REACT_MAX_STEP=10
PROMPTPILE_REACT_THOUGHT_PROMPT=./thought.md
PROMPTPILE_REACT_OBSERVE_PROMPT=./observe.md
PROMPTPILE_REACT_FINAL_PROMPT=./.final.md

PROMPTPILE_REACT_THOUGHT_LLM_API=deepseek
PROMPTPILE_REACT_OBSERVE_LLM_API=deepseek
PROMPTPILE_REACT_FINAL_LLM_API=deepseek
PROMPTPILE_REACT_THOUGHT_LLM_API_KEY=
PROMPTPILE_REACT_THOUGHT_LLM_API_KEY_ENV=
PROMPTPILE_REACT_THOUGHT_LLM_API_MODEL=
PROMPTPILE_REACT_THOUGHT_LLM_API_BASE_URL=
PROMPTPILE_REACT_OBSERVE_LLM_API_KEY=
PROMPTPILE_REACT_OBSERVE_LLM_API_KEY_ENV=
PROMPTPILE_REACT_OBSERVE_LLM_API_MODEL=
PROMPTPILE_REACT_OBSERVE_LLM_API_BASE_URL=
PROMPTPILE_REACT_FINAL_LLM_API_KEY=
PROMPTPILE_REACT_FINAL_LLM_API_KEY_ENV=
PROMPTPILE_REACT_FINAL_LLM_API_MODEL=
PROMPTPILE_REACT_FINAL_LLM_API_BASE_URL=
PROMPTPILE_REACT_THOUGHT_LLM_API_TEMPERATURE=
PROMPTPILE_REACT_OBSERVE_LLM_API_TEMPERATURE=
PROMPTPILE_REACT_FINAL_LLM_API_TEMPERATURE=
PROMPTPILE_REACT_THOUGHT_LLM_API_EXTRA_BODY=
PROMPTPILE_REACT_OBSERVE_LLM_API_EXTRA_BODY=
PROMPTPILE_REACT_CHECK_PROMPT=./check.md
PROMPTPILE_REACT_CHECK_LLM_API=deepseek
PROMPTPILE_REACT_CHECK_LLM_API_KEY=
PROMPTPILE_REACT_CHECK_LLM_API_KEY_ENV=
PROMPTPILE_REACT_CHECK_LLM_API_MODEL=
PROMPTPILE_REACT_CHECK_LLM_API_BASE_URL=
PROMPTPILE_REACT_CHECK_LLM_API_TEMPERATURE=
PROMPTPILE_REACT_CHECK_LLM_API_EXTRA_BODY=
PROMPTPILE_REACT_FINAL_LLM_API_EXTRA_BODY=

# --- 本包运行时开关（无 TOML 字段）---
# PROMPTPILE_BIN=
# PROMPTPILE_REACT_DEBUG=false
