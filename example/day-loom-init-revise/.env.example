# Copy to .env for run-interactive.* (do not commit .env)
DEEPSEEK_API_KEY=sk-...

# Optional: use a custom promptpile-mcp executable.
# PROMPTPILE_MCP_BIN=/absolute/path/to/promptpile-mcp

