{
  "name": "@web-editor/file-view-component",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/file-view-component.js",
  "module": "./dist/file-view-component.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/file-view-component.js"
    },
    "./icons": {
      "types": "./dist/ui/icons-entry.d.ts",
      "import": "./dist/file-view-component-icons.js"
    },
    "./file-view-component-icons.css": "./dist/file-view-component-icons.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && tsc --emitDeclarationOnly",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "happy-dom": "^17.4.4",
    "typescript": "~5.7.2",
    "vite": "^6.0.3",
    "vitest": "^3.1.4"
  }
}
